<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>

	<parent>
		<groupId>com.mugsun</groupId>
		<artifactId>mugsun-core</artifactId>
		<version>0.0.1-SNAPSHOT</version>
	</parent>

	<artifactId>mugsun-starter-mybatis</artifactId>
	<name>mugsun-starter-mybatis</name>
	<description>持久层基座：MyBatis-Flex + 实体基类</description>

	<dependencies>
		<dependency>
			<groupId>com.mugsun</groupId>
			<artifactId>mugsun-core-tool</artifactId>
			<version>${mugsun.version}</version>
		</dependency>
		<!-- 提供 DataSource 自动配置 + HikariCP，MyBatis-Flex 的 SqlSessionFactory 依赖 DataSource -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-jdbc</artifactId>
		</dependency>
		<dependency>
			<groupId>com.mybatis-flex</groupId>
			<artifactId>mybatis-flex-spring-boot-starter</artifactId>
			<version>${mybatis-flex.version}</version>
		</dependency>
		<!-- 覆盖 MyBatis-Flex 传递的旧版 mybatis-spring（与 Spring 6.2 冲突） -->
		<dependency>
			<groupId>org.mybatis</groupId>
			<artifactId>mybatis-spring</artifactId>
			<version>${mybatis-spring.version}</version>
		</dependency>
	</dependencies>
</project>
